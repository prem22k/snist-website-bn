# Email Configuration (Gmail API OAuth2)
EMAIL_USER=your_email@gmail.com

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/

# Server Configuration
PORT=5000

# Google OAuth2 Configuration (for Gmail API)
# Generate credentials at: https://console.cloud.google.com/
CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
CLIENT_SECRET=your_google_oauth_client_secret
REFRESH_TOKEN=your_google_oauth_refresh_token
# The redirect URI registered in your Google Cloud Console
OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground

# API Security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=generate_a_random_64_character_hex_string_here

# CORS Configuration — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://snist.cloudcommunityclub.tech,https://cloudcommunityclub-c3.vercel.app

# Admin Dashboard
ADMIN_PASSWORD=change_this_to_a_strong_admin_password
